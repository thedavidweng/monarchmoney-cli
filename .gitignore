#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Node
node_modules/

# pnpm build output
/dist/

# OS
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
.cursor/
.claude/
.commandcode/
.sisyphus/
.omx/
.gemini/
MEMORY.md

# Project Specific
/monarch
/docs/dev
session.json
config.yaml
/audit/
/cache/
*.sqlite

# Local worktrees
.worktrees/

# Build output
dist/
build/
out/
/output/
coverage/
test-audio/
website/_site/



